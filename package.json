{
  "name": "privatepod",
  "version": "1.0.0",
  "description": "A simple, self-hosted podcast hosting solution",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "docker:build": "docker build -t privatepod .",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "keywords": [
    "podcast",
    "rss",
    "mp3",
    "hosting",
    "docker"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^1.4.5-lts.2",
    "swagger-ui-express": "^5.0.1",
    "xml": "^1.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
